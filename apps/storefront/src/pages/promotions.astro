---
import BaseLayout from "../layouts/BaseLayout.astro"

const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:9000"

let promotions: Array<{ id: string; code: string; type: string; is_automatic: boolean }> = []

try {
  const res = await fetch(`${apiUrl}/api/store/promotions?limit=24`)
  if (res.ok) {
    const data = await res.json()
    promotions = data.promotions ?? []
  }
} catch {
  promotions = []
}
---

<BaseLayout title="促销活动">
  <h1 class="mb-6 text-2xl font-bold">促销活动</h1>

  {promotions.length === 0 ? (
    <p class="text-gray-500">当前没有进行中的促销</p>
  ) : (
    <ul class="space-y-3">
      {promotions.map((promo) => (
        <li class="rounded border bg-white p-4">
          <p class="font-mono text-lg font-semibold">{promo.code}</p>
          <p class="text-sm text-gray-500">类型：{promo.type} · {promo.is_automatic ? "自动应用" : "需输入优惠码"}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
