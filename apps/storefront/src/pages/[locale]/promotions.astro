---
import {
  buildLocaleIndexPaths,
  resolvePromotions,
  localeUrlPath,
  normalizeLocaleSegment,
  DEFAULT_LOCALE,
  isStaticContentMode,
} from "../../lib/i18n"
import BaseLayout from "../../layouts/BaseLayout.astro"

export async function getStaticPaths() {
  if (!isStaticContentMode()) return []
  return buildLocaleIndexPaths()
}

const localeParam = Astro.params.locale
const locale = localeParam
  ? normalizeLocaleSegment(localeParam) ?? DEFAULT_LOCALE
  : Astro.locals.locale ?? DEFAULT_LOCALE
Astro.locals.locale = locale

const promotions = await resolvePromotions(locale)
const site = Astro.site?.href ?? "http://localhost:4321"
---

<BaseLayout
  title="促销活动 — 跨境商城"
  description="当前可用的优惠码与自动促销活动。"
  canonical={`${site}${localeUrlPath(locale, "/promotions")}`}
>
  <h1 class="mb-6 text-2xl font-bold">促销活动</h1>

  {promotions.length === 0 ? (
    <p class="text-gray-500">当前没有进行中的促销</p>
  ) : (
    <ul class="space-y-3">
      {promotions.map((promo) => (
        <li class="rounded border bg-white p-4">
          <p class="font-mono text-lg font-semibold">{promo.code}</p>
          <p class="text-sm text-gray-500">
            类型：{promo.type} ·
            {promo.isAutomatic ? "自动应用" : "需输入优惠码"}
          </p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
