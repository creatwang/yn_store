---
import BaseLayout from "../layouts/BaseLayout.astro"

const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:9000"

let collections: Array<{ id: string; title: string; handle: string }> = []

try {
  const res = await fetch(`${apiUrl}/api/store/collections?limit=24`)
  if (res.ok) {
    const data = await res.json()
    collections = data.collections ?? []
  }
} catch {
  collections = []
}
---

<BaseLayout title="商品合集">
  <h1 class="mb-6 text-2xl font-bold">商品合集</h1>

  {collections.length === 0 ? (
    <p class="text-gray-500">暂无合集</p>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {collections.map((col) => (
        <a
          href={`/collections/${col.handle}`}
          class="block rounded border bg-white p-4 shadow-sm hover:shadow-md"
        >
          <h2 class="font-medium">{col.title}</h2>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
