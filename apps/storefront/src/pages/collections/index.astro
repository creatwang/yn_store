---
import { listCollections } from "../../lib/catalog"
import BaseLayout from "../../layouts/BaseLayout.astro"

const collections = await listCollections()
---

<BaseLayout
  title="商品合集 — 跨境商城"
  description="浏览全部商品合集与分类。"
>
  <h1 class="mb-6 text-2xl font-bold">商品合集</h1>

  {collections.length === 0 ? (
    <p class="text-gray-500">暂无合集</p>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {collections.map((collection) => (
        <a
          href={`/collections/${collection.handle}`}
          class="block rounded border bg-white p-4 shadow-sm hover:shadow-md"
        >
          <h2 class="font-medium">{collection.title}</h2>
          <p class="mt-1 text-sm text-gray-500">
            {collection.products.length} 件商品
          </p>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
