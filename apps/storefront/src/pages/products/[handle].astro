---
import BaseLayout from "../../layouts/BaseLayout.astro"

const { handle } = Astro.params
const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:9000"

let product: Record<string, unknown> | null = null
let error: string | null = null

try {
  const res = await fetch(`${apiUrl}/api/store/products/${handle}`)
  if (res.ok) {
    const data = await res.json()
    product = data.product
  } else {
    error = "商品不存在"
  }
} catch {
  error = "加载失败"
}
---

<BaseLayout title={product ? String(product.title) : "商品详情"}>
  {error && (
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
      {error}
      <a href="/" class="ml-2 underline">返回首页</a>
    </div>
  )}

  {product && (
    <article class="grid gap-8 md:grid-cols-2">
      <div>
        {product.thumbnail ? (
          <img
            src={String(product.thumbnail)}
            alt={String(product.title)}
            class="w-full rounded-lg object-cover"
          />
        ) : (
          <div class="flex aspect-square items-center justify-center rounded-lg bg-gray-100 text-gray-400">
            无图
          </div>
        )}
      </div>
      <div>
        <h1 class="text-3xl font-bold">{product.title}</h1>
        {product.subtitle && (
          <p class="mt-2 text-lg text-gray-600">{product.subtitle}</p>
        )}
        {product.description && (
          <div class="prose mt-6 max-w-none text-gray-700">
            <p>{product.description}</p>
          </div>
        )}
        <p class="mt-4 font-mono text-xs text-gray-400">
          {product.handle}
        </p>
        {(product.variants as Array<Record<string, unknown>> | undefined)?.length ? (
          <div class="mt-8 space-y-4">
            <label class="block text-sm font-medium">
              规格
              <select id="variant-select" class="mt-1 w-full rounded border px-3 py-2">
                {(product.variants as Array<Record<string, unknown>>).map((v) => (
                  <option value={String(v.id)}>{v.title || v.sku || v.id}</option>
                ))}
              </select>
            </label>
            <label class="block text-sm font-medium">
              数量
              <input id="qty-input" type="number" min="1" value="1" class="mt-1 w-24 rounded border px-3 py-2" />
            </label>
            <button
              id="add-to-cart"
              type="button"
              class="rounded bg-gray-900 px-6 py-2 text-white hover:bg-gray-800"
            >
              加入购物车
            </button>
            <p id="cart-msg" class="text-sm text-green-600"></p>
          </div>
        ) : (
          <p class="mt-6 text-sm text-gray-500">暂无可售规格</p>
        )}
      </div>
    </article>
  )}
</BaseLayout>

<script define:vars={{ productId: product?.id ?? "" }}>
  import { apiFetch, getCartId, setCartId } from "../../lib/cart"

  const btn = document.getElementById("add-to-cart")
  const msg = document.getElementById("cart-msg")
  const variantSelect = document.getElementById("variant-select")
  const qtyInput = document.getElementById("qty-input")

  btn?.addEventListener("click", async () => {
    if (!variantSelect || !qtyInput) return
    const variantId = variantSelect.value
    const quantity = Math.max(1, parseInt(qtyInput.value, 10) || 1)

    let cartId = getCartId()
    if (!cartId) {
      const createRes = await apiFetch("/store/carts", {
        method: "POST",
        body: JSON.stringify({ currency_code: "USD" }),
      })
      if (!createRes.ok) {
        if (msg) msg.textContent = "创建购物车失败"
        return
      }
      const created = await createRes.json()
      cartId = created.cart?.id
      if (cartId) setCartId(cartId)
    }

    const res = await apiFetch(`/store/carts/${cartId}/line-items`, {
      method: "POST",
      body: JSON.stringify({
        variant_id: variantId,
        product_id: productId,
        quantity,
      }),
    })

    if (res.ok) {
      if (msg) msg.textContent = "已加入购物车"
    } else {
      if (msg) msg.textContent = "加入失败"
    }
  })
</script>
