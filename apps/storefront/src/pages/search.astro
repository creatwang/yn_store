---
export const prerender = false
import BaseLayout from "../layouts/BaseLayout.astro"
import { localeUrlPath } from "../lib/i18n"
import { storeClient } from "../lib/api/index"
import ProductCard from "../components/product/ProductCard.astro"

const locale = Astro.locals.locale ?? "zh-CN"
const searchAction = localeUrlPath(locale, "/search")

const q = Astro.url.searchParams.get("q")?.trim() ?? ""
let products: Array<{
  id: string
  title: string
  handle: string
  thumbnail: string | null
  subtitle: string | null
  price: number | null
}> = []
let error: string | null = null

if (q) {
  try {
    const data = await storeClient.fetchJson<{ products?: typeof products }>(
      `/store/products?q=${encodeURIComponent(q)}&limit=48`,
    )
    products = data.products ?? []
  } catch {
    error = "搜索失败"
  }
}
---

<BaseLayout
  title={q ? `搜索「${q}」— 跨境商城` : "搜索 — 跨境商城"}
  description="搜索跨境商城商品。"
>
  <h1 class="mb-4 text-2xl font-bold">搜索</h1>

  <form action={searchAction} method="get" class="mb-8 flex gap-2">
    <label for="search-q" class="sr-only">关键词</label>
    <input
      id="search-q"
      name="q"
      type="search"
      value={q}
      placeholder="输入商品名或 handle"
      enterkeyhint="search"
      class="flex-1 rounded border border-gray-300 px-3 py-2"
    />
    <button
      type="submit"
      class="rounded bg-gray-900 px-4 py-2 text-sm text-white hover:bg-gray-800"
    >
      搜索
    </button>
  </form>

  {!q ? (
    <p class="text-gray-500">输入关键词开始搜索</p>
  ) : error ? (
    <p class="text-red-600">{error}</p>
  ) : products.length === 0 ? (
    <p class="text-gray-500">未找到相关商品</p>
  ) : (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <ProductCard
          handle={product.handle}
          title={product.title}
          subtitle={product.subtitle ?? undefined}
          thumbnail={product.thumbnail ?? undefined}
          price={product.price}
        />
      ))}
    </div>
  )}
</BaseLayout>
