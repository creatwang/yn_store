---
export const prerender = false
import BaseLayout from "../layouts/BaseLayout.astro"
import GoogleSignIn from "../components/GoogleSignIn.astro"

const redirect = Astro.url.searchParams.get("redirect")
if (redirect?.startsWith("/") && !redirect.startsWith("//")) {
  Astro.cookies.set("google_auth_redirect", redirect, {
    path: "/",
    maxAge: 600,
    sameSite: "lax",
    httpOnly: true,
  })
}

const errorParam = Astro.url.searchParams.get("error")
let errorMessage = ""
if (errorParam) {
  const map: Record<string, string> = {
    google_auth_failed: "Google 登录验证失败，请稍后重试",
    google_csrf: "安全验证失败，请刷新页面重试",
    google_bad_request: "登录请求格式错误",
    google_no_token: "登录成功但获取令牌失败",
    google_no_session: "登录会话已过期，请重新登录",
  }
  errorMessage = map[errorParam] || decodeURIComponent(errorParam)
}
---

<BaseLayout title="登录">
  <div class="mx-auto max-w-md rounded border bg-white p-6">
    <h1 class="mb-4 text-2xl font-bold">客户登录</h1>
    {errorMessage && (
      <p class="mb-4 rounded border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700">
        {errorMessage}
      </p>
    )}
    <form id="login-form" class="space-y-4">
      <label class="block text-sm">
        邮箱
        <input name="email" type="email" required class="mt-1 w-full rounded border px-3 py-2" />
      </label>
      <label class="block text-sm">
        密码
        <input name="password" type="password" required class="mt-1 w-full rounded border px-3 py-2" />
      </label>
      <p id="login-error" class="hidden text-sm text-red-600"></p>
      <button type="submit" class="w-full rounded bg-gray-900 px-4 py-2 text-white hover:bg-gray-800">
        登录
      </button>
    </form>
    <div class="mt-4 border-t pt-4">
      <p class="mb-3 text-center text-sm text-gray-500">或</p>
      <GoogleSignIn />
    </div>
    <p class="mt-4 text-center text-sm text-gray-600">
      还没有账号？<a href="/register" class="underline">注册</a>
    </p>
  </div>
</BaseLayout>

<script>
  import { loginCustomer, linkCartToCustomer, setSessionCookie } from "../lib/auth"
  import { getCartId } from "../lib/cart"

  const form = document.getElementById("login-form") as HTMLFormElement
  const errorEl = document.getElementById("login-error")!

  form.addEventListener("submit", async (e) => {
    e.preventDefault()
    errorEl.classList.add("hidden")
    const fd = new FormData(form)
    try {
      const data = await loginCustomer(
        String(fd.get("email")),
        String(fd.get("password")),
      )
      await setSessionCookie(data.token)
      const cartId = getCartId()
      if (cartId) await linkCartToCustomer(cartId)
      const redirect = new URLSearchParams(window.location.search).get("redirect")
      window.location.href = redirect || "/account"
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : "登录失败"
      errorEl.classList.remove("hidden")
    }
  })
</script>
