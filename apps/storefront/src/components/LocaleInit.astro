<script>
  import { storeClient } from "../lib/api"
  import { parseLocaleFromPathname } from "../lib/i18n/locale"

  function syncLocaleFromUrl() {
    const { locale } = parseLocaleFromPathname(window.location.pathname)
    storeClient.setLocale(locale)
  }

  syncLocaleFromUrl()
  window.addEventListener("popstate", syncLocaleFromUrl)
</script>
