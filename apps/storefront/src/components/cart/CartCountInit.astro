<!-- 页面加载时从 server cart 同步角标数量 -->
<script>
  import { apiFetch, getCartId } from "../../lib/cart"
  import { setCartCount } from "../../stores/cartStore"

  async function syncCartCount() {
    const cartId = getCartId()
    if (!cartId) return
    try {
      const res = await apiFetch(`/store/carts/${cartId}`)
      if (!res.ok) return
      const data = await res.json()
      const items = (data.items ?? data.cart?.items ?? []) as Array<{
        quantity?: number
      }>
      const total = items.reduce((sum, item) => sum + (item.quantity ?? 0), 0)
      setCartCount(total)
    } catch {
      /* 忽略同步失败，角标保持 0 或上次加购值 */
    }
  }

  syncCartCount()
</script>
