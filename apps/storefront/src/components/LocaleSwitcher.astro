---
import type { StoreLocaleOption } from "../lib/store-settings"
import { parseLocaleFromPathname, switchLocaleUrlPath } from "../lib/i18n"

interface Props {
  options?: StoreLocaleOption[]
}

const options = Astro.props.options ?? Astro.locals.storeLocaleOptions ?? []
const { locale: currentLocale } = parseLocaleFromPathname(
  Astro.url.pathname,
  Astro.locals.storeDefaultLocale,
)

const links = options.map((opt) => ({
  ...opt,
  href: switchLocaleUrlPath(Astro.url.pathname + Astro.url.search, opt.locale),
  active: opt.locale.toLowerCase() === currentLocale.toLowerCase(),
}))
---

{
  links.length > 1 ? (
    <div class="flex items-center gap-1 rounded border border-gray-200 bg-gray-50 p-0.5 text-xs">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded px-2 py-1 font-medium transition",
            link.active
              ? "bg-white text-gray-900 shadow-sm"
              : "text-gray-500 hover:text-gray-900",
          ]}
          hreflang={link.locale}
          aria-current={link.active ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
  ) : null
}
