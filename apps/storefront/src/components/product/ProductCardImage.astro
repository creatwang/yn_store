---
import { Image } from "astro:assets"
import placeholder from "../../assets/product-placeholder.svg"
import { resolveImageUrl } from "../../lib/media/images"

interface Props {
  src?: string | null
  alt: string
}

const { src, alt } = Astro.props
const resolvedSrc = resolveImageUrl(src)
const hasRemote = Boolean(resolvedSrc)
---

{
  hasRemote ? (
    <Image
      src={resolvedSrc!}
      alt={alt}
      width={400}
      height={400}
      layout="constrained"
      loading="lazy"
      decoding="async"
      class="h-48 w-full object-cover"
    />
  ) : (
    <Image
      src={placeholder}
      alt={alt}
      width={400}
      height={400}
      layout="constrained"
      loading="lazy"
      decoding="async"
      class="h-48 w-full object-cover"
    />
  )
}
