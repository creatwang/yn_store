---
import { formatMoney } from "../../lib/currency"

export interface VariantOption {
  id: string
  title?: string | null
  sku?: string | null
  priceAmount?: number | null
  stock?: number | null
}

interface Props {
  productId: string
  variants: VariantOption[]
  currency?: string
}

const { productId, variants, currency: currencyProp } = Astro.props
const currency = currencyProp ?? Astro.locals.currency ?? "usd"
const first = variants[0]
const initialPrice =
  first?.priceAmount != null ? formatMoney(first.priceAmount, currency) : ""
---

{
  variants.length > 0 ? (
    <form id="add-to-cart-form" class="mt-8 space-y-4">
      <p class="text-2xl font-bold text-gray-900">
        <span class="text-sm font-normal text-gray-600">价格 </span>
        {initialPrice ? (
          <output
            id="variant-price"
            name="price"
            for="variant-select"
            class="tabular-nums"
          >
            {initialPrice}
          </output>
        ) : (
          <output id="variant-price" name="price" for="variant-select">
            暂无定价
          </output>
        )}
      </p>

      <fieldset class="space-y-3 rounded-lg border border-gray-200 bg-white p-4">
        <legend class="px-1 text-sm font-medium text-gray-900">购买选项</legend>

        <div>
          <label for="variant-select" class="block text-sm font-medium text-gray-700">
            规格
          </label>
          <select
            id="variant-select"
            name="variant"
            class="mt-1 w-full rounded border border-gray-300 px-3 py-2"
          >
            {variants.map((v) => {
              const priceStr =
                v.priceAmount != null
                  ? ` — ${formatMoney(v.priceAmount, currency)}`
                  : " — 暂无定价"
              return (
                <option
                  value={v.id}
                  data-price={v.priceAmount != null ? String(v.priceAmount) : ""}
                >
                  {v.title || v.sku || v.id}
                  {priceStr}
                </option>
              )
            })}
          </select>
        </div>

        <div>
          <label for="qty-input" class="block text-sm font-medium text-gray-700">
            数量
          </label>
          <input
            id="qty-input"
            name="quantity"
            type="number"
            min="1"
            value="1"
            inputmode="numeric"
            enterkeyhint="done"
            class="mt-1 w-24 rounded border border-gray-300 px-3 py-2"
          />
        </div>
      </fieldset>

      <button
        id="add-to-cart"
        type="button"
        class="rounded bg-gray-900 px-6 py-2 text-white hover:bg-gray-800"
      >
        加入购物车
      </button>

      <p id="cart-msg" role="status" aria-live="polite" class="min-h-[1.25rem] text-sm" />
    </form>
  ) : (
    <p class="mt-6 text-sm text-gray-500">暂无可售规格</p>
  )
}

<script define:vars={{ productId, currency }}>
  import { apiFetch, getCartId, setCartId } from "../../lib/cart/index"
  import { formatMoney } from "../../lib/currency"
  import { incrementCart, decrementCart } from "../../stores/cartStore"

  const btn = document.getElementById("add-to-cart")
  const msg = document.getElementById("cart-msg")
  const variantSelect = document.getElementById("variant-select")
  const qtyInput = document.getElementById("qty-input")
  const priceEl = document.getElementById("variant-price")

  function formatPriceOutput(raw: string) {
    if (!priceEl) return
    if (!raw) {
      priceEl.textContent = "暂无定价"
      return
    }
    priceEl.textContent = formatMoney(raw, currency)
  }

  variantSelect?.addEventListener("change", () => {
    const selected = variantSelect.options[variantSelect.selectedIndex]
    formatPriceOutput(selected?.dataset.price ?? "")
  })

  btn?.addEventListener("click", async () => {
    if (!variantSelect || !qtyInput) return
    const variantId = variantSelect.value
    const quantity = Math.max(1, parseInt(qtyInput.value, 10) || 1)

    incrementCart(quantity)
    if (msg) {
      msg.textContent = ""
      msg.classList.remove("text-red-600")
      msg.classList.add("text-green-600")
    }

    try {
      let cartId = getCartId()
      if (!cartId) {
        const createRes = await apiFetch("/store/carts", {
          method: "POST",
          body: JSON.stringify({ currency_code: currency.toUpperCase() }),
        })
        if (!createRes.ok) throw new Error("create cart failed")
        const created = await createRes.json()
        cartId = created.cart?.id
        if (!cartId) throw new Error("no cart id")
        setCartId(cartId)
      }

      const res = await apiFetch(`/store/carts/${cartId}/line-items`, {
        method: "POST",
        body: JSON.stringify({
          variant_id: variantId,
          product_id: productId,
          quantity,
        }),
      })

      if (!res.ok) throw new Error("add failed")
      if (msg) msg.textContent = "已加入购物车"
    } catch {
      decrementCart(quantity)
      if (msg) {
        msg.textContent = "加入失败，请重试"
        msg.classList.remove("text-green-600")
        msg.classList.add("text-red-600")
      }
    }
  })
</script>
