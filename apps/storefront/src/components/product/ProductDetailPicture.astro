---
import { Picture, Image } from "astro:assets"
import placeholder from "../../assets/product-placeholder.svg"
import { resolveImageUrl } from "../../lib/images"

interface Props {
  src: string
  alt: string
}

const { src, alt } = Astro.props
const resolvedSrc = resolveImageUrl(src)
const hasRemote = Boolean(resolvedSrc)
---

{
  hasRemote ? (
    <Picture
      src={resolvedSrc!}
      alt={alt}
      width={800}
      height={800}
      formats={["avif", "webp"]}
      layout="constrained"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-full rounded-lg object-cover"
    />
  ) : (
    <Image
      src={placeholder}
      alt={alt}
      width={800}
      height={800}
      layout="constrained"
      loading="eager"
      fetchpriority="high"
      class="w-full rounded-lg object-cover"
    />
  )
}
