---
import ProductCardImage from "./ProductCardImage.astro"
import { formatMoney } from "../../lib/currency"
import { localeUrlPath } from "../../lib/i18n"

interface Props {
  handle: string
  title: string
  subtitle?: string
  thumbnail?: string
  price?: number | null
  currency?: string
}

const { handle, title, subtitle, thumbnail, price, currency: currencyProp } = Astro.props
const locale = Astro.locals.locale ?? "zh-CN"
const currency = currencyProp ?? Astro.locals.currency ?? "usd"
const productHref = localeUrlPath(locale, `/products/${handle}`)
---

<a
  href={productHref}
  class="block overflow-hidden rounded-lg border bg-white shadow-sm transition hover:shadow-md"
>
  <ProductCardImage src={thumbnail} alt={title} />
  <div class="p-4">
    <h2 class="font-medium">{title}</h2>
    {subtitle && <p class="mt-1 text-sm text-gray-500">{subtitle}</p>}
    <p class="mt-2 text-lg font-semibold text-gray-900">
      {price != null && price > 0
        ? formatMoney(price, currency)
        : "暂无定价"}
    </p>
  </div>
</a>
