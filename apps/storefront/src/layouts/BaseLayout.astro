---
import CartBadge from "../components/cart/CartBadge.astro"
import CartCountInit from "../components/cart/CartCountInit.astro"
import CurrencyInit from "../components/CurrencyInit.astro"
import CurrencySwitcher from "../components/CurrencySwitcher.astro"
import LocaleInit from "../components/LocaleInit.astro"
import LocaleSwitcher from "../components/LocaleSwitcher.astro"
import { storeClient } from "../lib/api"
import {
  DEFAULT_CURRENCY,
  buildCurrencyOptions,
  normalizeCurrencyCode,
  type CurrencyOption,
} from "../lib/currency"
import { localeUrlPath } from "../lib/i18n"

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
}

const {
  title = "商城",
  description = "跨境商城 — Hono Store API + Astro",
} = Astro.props

const locale = Astro.locals.locale ?? Astro.locals.storeDefaultLocale ?? "zh-CN"
const localeSwitchOptions = Astro.locals.storeLocaleOptions ?? []
const currency = normalizeCurrencyCode(Astro.locals.currency ?? DEFAULT_CURRENCY)

let currencyOptions: CurrencyOption[] = [
  { code: currency, label: currency.toUpperCase() },
]
try {
  const [currenciesRes, regionsRes] = await Promise.all([
    storeClient.fetchJson<{
      currencies?: Array<{ currency_code?: string | null }>
    }>("/store/currencies"),
    storeClient.fetchJson<{
      regions?: Array<{ id: string; name?: string | null; currency_code?: string | null }>
    }>("/store/regions?limit=100"),
  ])
  const built = buildCurrencyOptions(
    currenciesRes.currencies ?? [],
    regionsRes.regions ?? [],
  )
  if (built.length > 0) {
    currencyOptions = built
  }
} catch {
  /* 后端不可用时仍展示当前货币 */
}
const site = Astro.site?.href ?? "http://localhost:4321"
const canonical = Astro.props.canonical ?? new URL(Astro.url.pathname, site).href
const ogImage = Astro.props.ogImage
const noindex = Astro.locals.noindex ?? false
const homeHref = localeUrlPath(locale, "/")
const collectionsHref = localeUrlPath(locale, "/collections")
const promotionsHref = localeUrlPath(locale, "/promotions")
const accountHref = localeUrlPath(locale, "/account")
const loginHref = localeUrlPath(locale, "/login")
const cartHref = localeUrlPath(locale, "/cart")
const checkoutHref = localeUrlPath(locale, "/checkout")
const searchAction = localeUrlPath(locale, "/search")
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900"
    data-home-href={homeHref}
    data-account-href={accountHref}
    data-checkout-href={checkoutHref}
    data-currency={currency}
  >
    <LocaleInit />
    <CurrencyInit />
    <CartCountInit />
    <header class="border-b bg-white">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4">
        <a href={homeHref} class="text-xl font-semibold">跨境商城</a>
        <form action={searchAction} method="get" class="order-3 w-full sm:order-none sm:w-auto">
          <label for="site-search" class="sr-only">搜索商品</label>
          <input
            id="site-search"
            name="q"
            type="search"
            placeholder="搜索商品…"
            enterkeyhint="search"
            autocomplete="off"
            class="w-full rounded border border-gray-300 px-3 py-1.5 text-sm sm:w-48"
          />
        </form>
        <nav class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
          <LocaleSwitcher options={localeSwitchOptions} />
          <CurrencySwitcher current={currency} options={currencyOptions} />
          <a href={homeHref} class="hover:text-gray-900">首页</a>
          <a href={collectionsHref} class="hover:text-gray-900">合集</a>
          <a href={promotionsHref} class="hover:text-gray-900">促销</a>
          <CartBadge />
          <a href={accountHref} class="hover:text-gray-900">账户</a>
          <a href={loginHref} class="hover:text-gray-900">登录</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t py-8 text-center text-sm text-gray-500">
      <address class="not-italic">
        跨境商城 · Powered by Hono + Astro
      </address>
    </footer>
  </body>
</html>
