---
interface Props {
  title?: string
}

const { title = "商城" } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="border-b bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="text-xl font-semibold">跨境商城</a>
        <nav class="flex gap-4 text-sm text-gray-600">
          <a href="/" class="hover:text-gray-900">首页</a>
          <a href="/cart" class="hover:text-gray-900">购物车</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t py-8 text-center text-sm text-gray-500">
      Powered by Hono + Astro
    </footer>
  </body>
</html>
