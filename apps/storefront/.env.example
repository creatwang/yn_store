# 服务端根地址（页面内 fetch 已带 /api 前缀）
PUBLIC_API_URL=http://localhost:9000

# 站点 canonical / sitemap / OG 绝对 URL
PUBLIC_SITE_URL=http://localhost:4321

# Astro 部署适配器：node（默认）| vercel | cloudflare
# ASTRO_DEPLOY_TARGET=node

# 生产 Node 运行时（pnpm start）
# HOST=0.0.0.0
# PORT=4321

# 可选：追加商品图 CDN 域名（逗号分隔）
# PUBLIC_IMAGE_DOMAINS=cdn.example.com

# Cloudflare 部署时：ASTRO_DEPLOY_TARGET=cloudflare + pnpm add @astrojs/cloudflare

# Server webhook（apps/server）
# WEBHOOK_SECRET=your-secret
# DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
