# 服务端根地址（页面内 fetch 已带 /api 前缀）
PUBLIC_API_URL=http://localhost:7000

# 站点 canonical / sitemap / OG 绝对 URL
PUBLIC_SITE_URL=http://localhost:4321

# Astro 渲染：server（全 SSR，dev 快，默认）| static（Hybrid SSG + Content Loader，产线 SEO）
# ASTRO_OUTPUT=server
# 产线 build 示例：ASTRO_OUTPUT=static pnpm build
# SSG 预渲染语言（逗号分隔，默认 zh-CN,en-US 与顶栏切换一致）
# PUBLIC_SSG_LOCALES=zh-CN,en-US
# 默认语言（无前缀 / 重定向目标）
# PUBLIC_DEFAULT_LOCALE=zh-CN

# 默认结算货币（ISO 4217 小写，如 usd / cny / eur）
# PUBLIC_DEFAULT_CURRENCY=usd

# Astro 部署适配器：node（默认）| vercel | cloudflare
# ASTRO_DEPLOY_TARGET=node

# Google OAuth Client ID（Google Sign-In 按钮，redirect 模式）
# PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
PUBLIC_GOOGLE_CLIENT_ID=742520717-ibt2q57d7kka1fbagahqf73essmu03rm.apps.googleusercontent.com
#
# Google Console → 已获授权的重定向 URI（与当前访问 origin 一致）：
#   http://localhost:4321/api/auth/google/callback
#   http://127.0.0.1:4321/api/auth/google/callback
# JavaScript 来源仍需添加对应 origin（不含路径）

# 生产 Node 运行时（pnpm start）
# HOST=0.0.0.0
# PORT=4321

# 可选：追加商品图 CDN 域名（逗号分隔）
# PUBLIC_IMAGE_DOMAINS=cdn.example.com

# Cloudflare 部署时：ASTRO_DEPLOY_TARGET=cloudflare + pnpm add @astrojs/cloudflare

# Server webhook（apps/server）
# WEBHOOK_SECRET=your-secret
# DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
