# 必填：PostgreSQL 连接串（本项目使用 Medusa 已有表，推荐 Supabase）
# Supabase: 项目 Settings → Database → Connection string → URI（Transaction 或 Session 均可）
# 示例（请替换为你的真实地址与密码）:
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# 仅本地有 PostgreSQL 时使用:
DATABASE_URL=postgresql://postgres:password@localhost:5432/medusa

JWT_SECRET=change-me-to-a-secure-secret-at-least-32-chars
PORT=9000
NODE_ENV=development

# Admin 静态 UI（build:admin → apps/server/public/app）
# SERVE_ADMIN=0          # 仅 API（Worker 等）
# ADMIN_STATIC_ROOT=public/app

# 商城跨域（逗号分隔，如 https://shop.example.com）
# STORE_CORS_ORIGIN=
# CORS_ORIGIN=

# 可选：pnpm seed:admin 使用的默认邮箱/密码（也可命令行传参）
# SEED_ADMIN_EMAIL=admin@medusa-test.com
# SEED_ADMIN_PASSWORD=supersecret
