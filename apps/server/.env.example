# 必填：PostgreSQL 连接串（推荐 Supabase）
# Supabase → Settings → Database → Connection string
#
# DATABASE_URL=postgresql://...@....pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/yanan

# Druid 式连接池（占满排队；DB_MAX_WAIT_MS=0 为无限等待）
DB_POOL_MAX=20
DB_MAX_WAIT_MS=0
DB_CONNECT_TIMEOUT=60
DB_IDLE_TIMEOUT=60
DB_MAX_LIFETIME=600

JWT_SECRET=change-me-to-a-secure-secret-at-least-32-chars
PORT=7000
NODE_ENV=development

# Admin 静态 UI（build:admin → apps/server/public/app）
# SERVE_ADMIN=0          # 仅 API（Worker 等）
# ADMIN_STATIC_ROOT=public/app

# 商城跨域（逗号分隔，如 https://shop.example.com）
# STORE_CORS_ORIGIN=
# CORS_ORIGIN=

# 可选：pnpm seed:admin 使用的默认邮箱/密码（也可命令行传参）
# SEED_ADMIN_EMAIL=admin@yanan-test.com
# SEED_ADMIN_PASSWORD=supersecret

# 邮件 (Resend HTTP API，未配置时回退到 console.log 占位)
# RESEND_API_KEY=re_xxxxxx
# 发件人地址按场景自动选择：
#   system   → noreply@mail.yanan.store  （密码重置、邀请等系统通知）
#   verify   → verify@mail.yanan.store   （注册验证）
#   order    → order@mail.yanan.store    （订单确认、取消）
#   shipping → shipping@mail.yanan.store （备货、发货、送达）
#   returns  → returns@mail.yanan.store  （退货、退款）
# 如需全部覆盖为单一地址，设置 SMTP_FROM
# SMTP_FROM="Yanan Store <noreply@mail.yanan.store>"
