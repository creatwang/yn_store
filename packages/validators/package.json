{
  "name": "@my-store/validators",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./medusa/*": {
      "types": "./src/medusa/*.ts",
      "default": "./src/medusa/*.ts"
    },
    "./helpers/*": {
      "types": "./src/helpers/*.ts",
      "default": "./src/helpers/*.ts"
    },
    "./admin-list-params": {
      "types": "./src/admin-list-params.ts",
      "default": "./src/admin-list-params.ts"
    }
  },
  "dependencies": {
    "zod": "^4.2.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
